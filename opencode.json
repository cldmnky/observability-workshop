{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/**/*.md"
  ],
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "build": {
      "prompt": "{file:./AGENTS.md}"
    },
    "plan": {
      "prompt": "{file:./AGENTS.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "ask"
      }
    }
  }
}
